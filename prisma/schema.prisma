generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model relationship {
  id              Int   @id(map: "pk_relationship") @default(autoincrement())
  source_skill_id Int
  target_skill_id Int
  source_skill    skill @relation("relationship_source_skill_idToskill", fields: [source_skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_relationship_skill")
  target_skill    skill @relation("relationship_target_skill_idToskill", fields: [target_skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_relationship_skill_0")

  @@unique([source_skill_id, target_skill_id], name: "source_target")
}

model skill {
  id              Int            @id(map: "pk_skill") @default(autoincrement())
  name            String         @unique
  image           String?
  recommended     Boolean        @default(true) 
  importance      Int            @default(30) 
  parents         relationship[] @relation("relationship_source_skill_idToskill")
  children        relationship[] @relation("relationship_target_skill_idToskill")
  user_skill      user_skill[]
}

model user_skill {
  id                 Int                 @id(map: "pk_user-skill") @default(autoincrement())
  user_id            String              @db.VarChar(100)
  skill_id           Int
  proficiency_levels proficiency_level[]
  skill              skill               @relation(fields: [skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user-skill_skill")

  @@unique([user_id, skill_id], name: "skill_user")
  @@map("user_skill")
}

model proficiency_level {
  id            Int        @id(map: "pk_proficiency-level") @default(autoincrement())
  user_skill_id Int
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime?  @updatedAt @map("updated_at")
  level         Int        @default(0)
  user_skill    user_skill @relation(fields: [user_skill_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_proficiency_level_user-skill")

  @@map("proficiency_level")
}